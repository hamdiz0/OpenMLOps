# ===========================================
# MLOps Pipeline Environment Configuration
# ===========================================
# Copy this file to .env and update the values
# DO NOT commit .env to version control!
# ===========================================

# MinIO Configuration (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# PostgreSQL Configuration
POSTGRES_USER=mlops
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=mlflow

# MLflow Configuration
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts

# ZenML Configuration
ZENML_DATABASE=zenml

# Note: The following are auto-derived from above values in docker-compose.yml
# AWS_ACCESS_KEY_ID - derived from MINIO_ROOT_USER
# AWS_SECRET_ACCESS_KEY - derived from MINIO_ROOT_PASSWORD
# MLFLOW_BACKEND_STORE_URI - constructed from POSTGRES_* vars
# ZENML_STORE_URL - constructed from POSTGRES_* vars
